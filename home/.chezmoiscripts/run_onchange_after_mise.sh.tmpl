#!/bin/bash

# mise.toml hash: {{ include "dot_config/mise/config.toml.tmpl" | sha256sum }}
mise install -y

{{- if eq .chezmoi.os "linux" }}
usage --completions zsh > /usr/local/share/zsh/site-functions/_usage
atuin gen-completion --shell zsh > /usr/local/share/zsh/site-functions/_atuin
{{ end }}
bws completions zsh > /usr/local/share/zsh/site-functions/_bws
