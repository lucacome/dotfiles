{{- $update := "" -}}
{{- if eq .chezmoi.os "darwin" -}}
{{- $update = "brew update && brew upgrade --greedy && brew upgrade --cask --greedy && brew cleanup" -}}
{{- else if eq .osid "linux-debian" -}}
{{- $update = "apt-get update && apt-get dist-upgrade -y && apt-get --purge autoremove -y && apt-get autoclean -y" -}}
{{- end -}}
{{- if lookPath "mise" -}}
{{- $update = printf "%s && mise outdated --bump && mise up --bump --yes && mise ls --prunable && mise prune --yes" $update -}}
{{- end -}}
{{- if lookPath "npm" -}}
{{- $update = printf "%s && npm install -g npm" $update -}}
{{- end -}}
{{- if lookPath "gh" -}}
{{- $update = printf "%s && gh extension upgrade --all" $update -}}
{{- end -}}
alias update='{{ $update }}'

{{- if lookPath "bat" }}
alias cat=bat
{{- else if lookPath "batcat" }}
alias cat=batcat
{{- end }}
{{- if lookPath "fdfind" }}
alias fd=fdfind
{{- end }}
{{- if lookPath "eza" }}
alias ls=eza
alias la='eza -gla --git'
alias ll='eza -gl --git'
alias lrt='eza -gl -snewest --git'
alias lart='eza -gla -snewest --git'
{{- end }}
